NODE_ENV=production
PORT=10000
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/voicecall?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
CLIENT_URL=https://voicecall.vercel.app
SOCKET_CORS_ORIGIN=https://voicecall.vercel.app
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
ENCRYPTION_KEY=your_32_byte_encryption_key_change
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000
