# Base URL for REST API. In dev, Vite proxies /api to the backend.
# Must include the /api prefix because backend routes are mounted under /api.
VITE_API_URL=/api

# Socket.IO URL. Leave empty to use the same origin (Vite proxies /socket.io).
VITE_SOCKET_URL=

# TURN server for WebRTC (strongly recommended for production / mobile networks).
# Leave empty to use only STUN. For a reliable TURN service, use Metered, Twilio, or Xirsys.
VITE_TURN_SERVER_URL=
VITE_TURN_USERNAME=
VITE_TURN_PASSWORD=
