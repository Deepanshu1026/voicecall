# IMPORTANT: VITE_API_URL must end with /api because all backend routes are mounted under /api
# If frontend and backend share the same origin (e.g. single Render service), use /api
VITE_API_URL=/api

# Socket.IO server URL. Leave empty to use the same origin.
VITE_SOCKET_URL=

# TURN server for WebRTC (strongly recommended for production / mobile networks).
# Option 1: Metered / Open Relay REST API (recommended)
# Sign up at https://www.metered.ca/tools/openrelay/ or https://metered.ca/stun-turn
# Get your app name and API key from the dashboard.
VITE_TURN_APP_NAME=
VITE_TURN_API_KEY=

# Option 2: Static TURN credentials
VITE_TURN_SERVER_URL=
VITE_TURN_USERNAME=
VITE_TURN_PASSWORD=
